// ============================================================
// YT Wallah — Prisma Schema (SQLite)
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("TURSO_DATABASE_URL")
}

model Channel {
  id                String   @id @default(cuid())
  name              String
  youtubeChannelId  String
  description       String   @default("")
  thumbnailUrl      String   @default("")
  bannerUrl         String   @default("")
  subscriberCount   String   @default("")
  videoCount        String   @default("")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  batches Batch[]
  videos  Video[]
}

model Batch {
  id           String   @id @default(cuid())
  name         String
  channelId    String
  description  String   @default("")
  thumbnailUrl String   @default("")
  subjects     String   @default("[]") // JSON array stored as string
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  videos  Video[]
}

model Video {
  id              String   @id @default(cuid())
  title           String
  youtubeVideoId  String
  channelId       String
  batchId         String
  subject         String   @default("")
  description     String   @default("")
  thumbnailUrl    String   @default("")
  duration        String   @default("")
  type            String   @default("video") // video | live | short
  isLive          Boolean  @default(false)
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  notes   Note[]
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("global") // global | batch
  batchId   String?
  priority  String   @default("medium") // low | medium | high | urgent
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  expiresAt DateTime?
}

model Note {
  id        String   @id @default(cuid())
  videoId   String
  userId    String
  content   String
  timestamp Int      @default(0) // seconds in video
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

model SiteSettings {
  id              String  @id @default("default")
  siteName        String  @default("YT Wallah")
  siteTagline     String  @default("Distraction-Free Learning from Physics Wallah")
  siteDescription String  @default("")
  logoUrl         String  @default("")
  primaryColor    String  @default("#7c3aed")
  accentColor     String  @default("#ec4899")
  footerText      String  @default("© 2026 YT Wallah. Built with ❤️ for students.")
  socialLinks     String  @default("{}") // JSON object stored as string
  maintenanceMode Boolean @default(false)
  welcomeMessage  String  @default("")
  youtubeApiKey   String  @default("")
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // hashed
  role      String   @default("admin") // superadmin | admin | moderator
  createdAt DateTime @default(now())
}

model UserChannel {
  id               String   @id @default(cuid())
  userEmail        String
  youtubeChannelId String
  channelName      String
  thumbnailUrl     String   @default("")
  subscriberCount  String   @default("")
  description      String   @default("")
  addedAt          DateTime @default(now())

  @@unique([userEmail, youtubeChannelId])
  @@index([userEmail])
}

model Student {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String
  city        String
  state       String
  country     String
  pincode     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  watchHistory WatchHistory[]
  likedVideos  LikedVideo[]
}

model WatchHistory {
  id               String   @id @default(cuid())
  studentEmail     String
  youtubeVideoId   String
  title            String
  thumbnailUrl     String   @default("")
  channelName      String   @default("")
  duration         String   @default("")
  watchedAt        DateTime @default(now())
  progressSeconds  Int      @default(0)

  student Student @relation(fields: [studentEmail], references: [email], onDelete: Cascade)

  @@index([studentEmail])
  @@unique([studentEmail, youtubeVideoId])
}

model LikedVideo {
  id               String   @id @default(cuid())
  studentEmail     String
  youtubeVideoId   String
  title            String
  thumbnailUrl     String   @default("")
  channelName      String   @default("")
  duration         String   @default("")
  likedAt          DateTime @default(now())

  student Student @relation(fields: [studentEmail], references: [email], onDelete: Cascade)

  @@index([studentEmail])
  @@unique([studentEmail, youtubeVideoId])
}
